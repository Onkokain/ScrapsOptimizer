{
  "manifest_version": 3,
  "name": "Scraps Optimizer",
  "version": "1.0.1",
  "description": "Analyzes Hack Club Scraps shop and refinery for optimal spending",
  "permissions": ["storage"],
  "host_permissions": ["https://scraps.hackclub.com/*"],
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://scraps.hackclub.com/shop", "https://scraps.hackclub.com/refinery"],
      "js": ["content_shop.js", "refinery_decision.js", "target_probability.js", "optimal_target.js", "overlay.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://scraps.hackclub.com/refinery"],
      "js": ["content_refinery.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16x16.png",
      "48": "icons/48x48.png",
      "128": "icons/128x128.png"
    }
  }
}
